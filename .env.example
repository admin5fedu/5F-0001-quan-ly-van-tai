# mock = dữ liệu mẫu trong mocks/ (mặc định dev). supabase = nối DB thật.
VITE_DATA_SOURCE=mock

# Khi nối Supabase: copy file này thành .env.local (không commit .env.local).
# SUPABASE_SECRET_KEY chỉ dùng server-side / scripts QA — không đưa vào git.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
DATABASE_URL=

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
